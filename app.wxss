/* ============================================
   宝宝成长度量 - 全局样式系统 v3.0
   设计规范：轻量化软拟态 + 扁平化融合设计 + 微动效
   ============================================ */

page {
  /* 主色系 */
  --primary: #A8D8EA;        /* 清冷蓝绿 */
  --primary-light: #D6EEF5;  /* 浅蓝 */
  --secondary: #FFD3B4;      /* 暖杏 */
  --accent: #C7CEEA;         /* 淡紫灰 */
  --accent-light: #E8EBF7;   /* 浅紫 */

  /* 文字层级 */
  --text-primary: #1A2A3A;
  --text-secondary: #4A5B6E;
  --text-light: #8A9BAA;

  /* 背景与卡片 */
  --white: #FFFFFF;
  --bg: #F5F9FC;
  --card-bg: rgba(255, 255, 255, 0.75);

  /* 阴影 - 极轻柔 */
  --shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  --shadow-hover: 0 8px 30px rgba(0, 0, 0, 0.08);

  /* 圆角 */
  --radius: 24px;      /* 卡片/按钮大圆角 */
  --radius-lg: 24px;   /* 同大圆角 */
  --radius-sm: 12px;   /* 输入框/标签小圆角 */

  /* 字体 */
  --font-title: 36rpx;   /* 标题 18px */
  --font-body: 30rpx;    /* 正文 15px */
  --font-caption: 26rpx; /* 辅助 13px */

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  color: var(--text-primary);
  font-size: var(--font-body);
  line-height: 1.6;
}

/* ============================================
   微动效系统 - 动画关键帧
   ============================================ */

/* 卡片入场 - 从下方淡入上移 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 从缩放淡入 */
@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 从左侧滑入 */
@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 从右侧滑入 */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 轻柔脉冲呼吸 */
@keyframes gentlePulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.04);
    opacity: 0.92;
  }
}

/* 浮动摇摆 */
@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 轻微浮动（用于按钮） */
@keyframes floatLight {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
}

/* 流光shimmer */
@keyframes shimmer {
  0% {
    background-position: -200% center;
  }
  100% {
    background-position: 200% center;
  }
}

/* 弹入 */
@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.6);
  }
  60% {
    transform: scale(1.08);
  }
  80% {
    transform: scale(0.96);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 旋转进入 */
@keyframes rotateIn {
  from {
    opacity: 0;
    transform: rotate(-10deg) scale(0.9);
  }
  to {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
}

/* 宽度伸展（进度条用） */
@keyframes stretchIn {
  from {
    width: 0;
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 涟漪扩散 */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 0.6;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

/* ============================================
   动画工具类
   ============================================ */

/* 入场动画基类 */
.anim-enter {
  animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.anim-enter-scale {
  animation: scaleIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.anim-enter-left {
  animation: slideInLeft 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.anim-enter-right {
  animation: slideInRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.anim-pop {
  animation: popIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

/* 交错延迟工具类 */
.anim-delay-1 { animation-delay: 0.05s; }
.anim-delay-2 { animation-delay: 0.1s; }
.anim-delay-3 { animation-delay: 0.15s; }
.anim-delay-4 { animation-delay: 0.2s; }
.anim-delay-5 { animation-delay: 0.25s; }
.anim-delay-6 { animation-delay: 0.3s; }
.anim-delay-7 { animation-delay: 0.35s; }
.anim-delay-8 { animation-delay: 0.4s; }
.anim-delay-9 { animation-delay: 0.45s; }
.anim-delay-10 { animation-delay: 0.5s; }

/* 脉冲效果 */
.anim-pulse {
  animation: gentlePulse 2.5s ease-in-out infinite;
}

/* 浮动效果 */
.anim-float {
  animation: float 3s ease-in-out infinite;
}

/* 轻浮动（用于按钮等） */
.anim-float-light {
  animation: floatLight 2s ease-in-out infinite;
}

/* 流光效果 */
.anim-shimmer {
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.4) 50%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: shimmer 2s ease-in-out infinite;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  border: none;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-hover);
}

.card-hover {
  box-shadow: var(--shadow-hover);
  transform: translateY(-2px);
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: var(--white);
  border-radius: 50rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
}

/* 按钮涟漪 */
.btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 10%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s ease;
  border-radius: inherit;
  pointer-events: none;
}

.btn-primary:active::after {
  opacity: 1;
  transition: opacity 0s;
}

.btn-secondary {
  background: var(--white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.btn-secondary:active {
  transform: scale(0.95);
  background: var(--primary-light);
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: var(--font-caption);
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.tag-green {
  background: #D4EDDA;
  color: #3A7D5A;
}

.tag-gray {
  background: #F0F2F5;
  color: var(--text-light);
}

.tag-primary {
  background: var(--primary-light);
  color: #5A9BAB;
}

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
  animation: float 3s ease-in-out infinite;
}

.empty-state .empty-text {
  color: var(--text-secondary);
  font-size: var(--font-body);
  margin-bottom: 32rpx;
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, #f0f2f5 25%, #e8ecf2 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.8s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ===== 页面通用容器 ===== */
.page-container {
  padding: 0 24px;
  padding-bottom: 32px;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg);
}

/* 页面入场 */
.page-container.entered .card,
.page-container.entered .test-item,
.page-container.entered .record-item,
.page-container.entered .baby-card {
  animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: #E8ECF0;
  margin: 16rpx 0;
}
