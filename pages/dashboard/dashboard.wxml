<!-- 跟踪看板页 -->
<view class="page-container" style="--primary: {{theme.primary}}; --primary-light: {{theme.primaryLight}}; --secondary: {{theme.secondary}}; --accent: {{theme.accent}}; --accent-light: {{theme.accentLight}}; --primary-rgba02: {{theme.primaryRgba02}}; --primary-rgba015: {{theme.primaryRgba015}}; --primary-rgba01: {{theme.primaryRgba01}}; --primary-rgba025: {{theme.primaryRgba025}}; --primary-rgba035: {{theme.primaryRgba035}}; --primary-rgba018: {{theme.primaryRgba018}}; --secondary-rgba01: {{theme.secondaryRgba01}}; --secondary-rgba015: {{theme.secondaryRgba015}};">
  <view class="nav-bar">
    <view class="nav-bar-left" bind:tap="openDrawer">
      <view class="hamburger">
        <view class="hamburger-line"></view>
        <view class="hamburger-line"></view>
        <view class="hamburger-line"></view>
      </view>
    </view>
    <view class="nav-bar-title">跟踪看板</view>
    <view class="nav-bar-right"></view>
  </view>

  <block wx:if="{{currentBaby}}">
    <!-- 宝宝信息 -->
    <view class="baby-bar">
      <text class="baby-avatar">{{currentBaby.gender === 'male' ? '👦' : currentBaby.gender === 'female' ? '👧' : '👶'}}</text>
      <view class="baby-info">
        <text class="baby-name">{{currentBaby.name}}</text>
        <text class="baby-age">{{babyAge}}个月</text>
      </view>
    </view>

    <!-- 雷达图 -->
    <view class="section" wx:if="{{radarData}}">
      <text class="section-title">综合能力雷达图</text>
      <view class="radar-wrap">
        <canvas type="2d" id="dashRadarCanvas" class="radar-canvas"></canvas>
      </view>
    </view>

    <!-- 维度筛选 -->
    <view class="filter-tags" wx:if="{{radarData}}">
      <text class="filter-item {{activeFilter === 'focus' ? 'active' : ''}}" bind:tap="setFilter" data-key="focus">专注力</text>
      <text class="filter-item {{activeFilter === 'emotion' ? 'active' : ''}}" bind:tap="setFilter" data-key="emotion">情绪</text>
      <text class="filter-item {{activeFilter === 'social' ? 'active' : ''}}" bind:tap="setFilter" data-key="social">社交</text>
      <text class="filter-item {{activeFilter === 'sensory' ? 'active' : ''}}" bind:tap="setFilter" data-key="sensory">感知</text>
    </view>

    <!-- 分组测试记录 -->
    <view class="section">
      <text class="section-title">测试记录</text>
      <view class="record-groups" wx:if="{{groupedRecords.length > 0}}">
        <view class="group-folder" wx:for="{{groupedRecords}}" wx:key="testType">
          <!-- 文件夹头 -->
          <view class="folder-header" bind:tap="toggleGroup" data-type="{{item.testType}}">
            <view class="folder-header-left">
              <text class="folder-icon">{{item.icon}}</text>
              <text class="folder-name">{{item.name}}</text>
              <text class="folder-count">{{item.records.length}}次</text>
            </view>
            <text class="folder-arrow {{groupExpand[item.testType] ? 'expanded' : ''}}">▶</text>
          </view>
          <!-- 文件夹内容 -->
          <view class="folder-body {{groupExpand[item.testType] ? 'show' : ''}}">
            <view class="timeline">
              <view class="timeline-line"></view>
              <view class="timeline-item" wx:for="{{item.records}}" wx:key="_id" wx:for-item="record" style="animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) {{0.08 * index}}s both;">
                <view class="timeline-dot" style="background: {{record.dotColor}};"></view>
                <view class="timeline-card card" bind:tap="goResult" data-id="{{record._id}}" data-type="{{record.testType}}">
                  <view class="timeline-card-header">
                    <text class="tc-date">{{record.completedAtStr}}</text>
                    <text class="tc-baby-age" wx:if="{{record.babyAge != null}}">{{record.babyAge}}个月</text>
                  </view>
                  <text class="tc-summary">{{record.summary || '查看详情'}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:else>
        <text class="empty-icon">📊</text>
        <text class="empty-text">还没有测试记录</text>
        <text class="empty-desc">去测一测吧~</text>
        <button class="btn-primary btn-small" bind:tap="goTests" style="margin-top: 20rpx;">去测试</button>
      </view>
    </view>
  </block>

  <!-- 无宝宝提示 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">👶</text>
    <text class="empty-text">请先添加宝宝信息</text>
    <button class="btn-primary btn-small" bind:tap="goBabies" style="margin-top: 20rpx;">去添加</button>
  </view>

  <nav-drawer
    visible="{{drawerVisible}}"
    currentPath="/pages/dashboard/dashboard"
    bind:close="closeDrawer"
    bind:navigate="onNavigate"
  ></nav-drawer>
</view>
