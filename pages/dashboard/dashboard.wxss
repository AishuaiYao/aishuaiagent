/* 跟踪看板 - 软拟态设计 */

.page-container {
  padding: 0 24px;
  padding-bottom: 32px;
  min-height: 100vh;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 4px;
  padding-top: env(safe-area-inset-top);
}

.nav-bar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.hamburger {
  width: 44rpx;
  height: 36rpx;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hamburger-line {
  height: 4rpx;
  background: #1A2A3A;
  border-radius: 2rpx;
}

.baby-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 8rpx;
}

.baby-avatar {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.baby-info {
  display: flex;
  flex-direction: column;
}

.baby-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.baby-age {
  font-size: 26rpx;
  color: #8A9BAA;
}

.section {
  margin-top: 32px;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-bottom: 16rpx;
  display: block;
}

.radar-wrap {
  width: 100%;
  height: 460rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.radar-canvas {
  width: 100%;
  height: 100%;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  justify-content: center;
}

.filter-item {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: #4A5B6E;
  background: #F0F2F5;
  transition: all 0.2s ease;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item.active {
  background: #F0F8FB;
  color: #5A9BAB;
  font-weight: 600;
  animation: scaleIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}

/* 时间线 */
.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline-line {
  position: absolute;
  left: 15rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: #E8ECF0;
}

.timeline-item {
  position: relative;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -23rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--primary);
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 2px 8px var(--primary-rgba025);
}

.timeline-card {
  padding: 20rpx 24rpx;
  margin-left: 16rpx;
  border-radius: var(--radius);
  background: var(--white);
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
}

.timeline-card:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-hover);
}

.timeline-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.tc-test-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.tc-date {
  font-size: 22rpx;
  color: #8A9BAA;
}

.tc-baby-age {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

.tc-summary {
  font-size: 24rpx;
  color: #4A5B6E;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.tc-tag-row {
  display: flex;
  gap: 8rpx;
}

/* 分组文件夹 */
.record-groups {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.group-folder {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.folder-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  transition: background 0.2s ease;
}

.folder-header:active {
  background: #F5F7FA;
}

.folder-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.folder-icon {
  font-size: 36rpx;
}

.folder-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.folder-count {
  font-size: 22rpx;
  color: #8A9BAA;
  background: #F0F2F5;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.folder-arrow {
  font-size: 22rpx;
  color: #8A9BAA;
  transition: transform 0.3s ease;
  transform: rotate(0deg);
}

.folder-arrow.expanded {
  transform: rotate(90deg);
}

/* 文件夹内容区域 - 高度过渡 */
.folder-body {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.folder-body.show {
  max-height: 2000rpx;
  opacity: 1;
  padding: 0 24rpx 16rpx 8rpx;
}

.folder-body .timeline {
  padding-left: 0;
  margin-left: 6rpx;
}

.folder-body .timeline-line {
  left: -9rpx;
}

.folder-body .timeline-dot {
  left: -17rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-light);
  color: #5A9BAB;
}

.tag-green {
  background: #D4EDDA;
  color: #3A7D5A;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #4A5B6E;
}

.empty-desc {
  font-size: 24rpx;
  color: #8A9BAA;
  margin-top: 8rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: #FFFFFF;
  border-radius: 50rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4px 20px var(--primary-rgba015);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
}
