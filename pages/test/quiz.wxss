/* 测试答题页 - 软拟态设计 */

.page-container {
  padding: 24px;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #E8ECF0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 6rpx;
  transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

/* 进度条流光 */
.progress-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.5) 50%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: shimmer 2s ease-in-out infinite;
}

.progress-text {
  font-size: 24rpx;
  color: #8A9BAA;
  min-width: 80rpx;
  text-align: right;
}

/* 题目卡片滑动动画容器 */
.question-anim-wrap {
  overflow: hidden;
  margin-bottom: 32rpx;
}

.slide-anim {
  animation-duration: 0.35s;
  animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  animation-fill-mode: both;
}

/* 题目卡片 */
.question-card {
  padding: 40rpx 32rpx;
  text-align: center;
  border-radius: var(--radius);
  background: var(--white);
  box-shadow: var(--shadow);
}

.question-number {
  font-size: 24rpx;
  color: var(--primary);
  margin-bottom: 20rpx;
  display: block;
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2A3A;
  line-height: 1.6;
}

/* 选项列表 */
.options-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  border: none;
  box-shadow: var(--shadow);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.option-item:active {
  transform: scale(0.97);
}

.option-item.selected {
  background: linear-gradient(135deg, #F0F8FB, #FFFFFF);
  box-shadow: 0 4px 20px var(--primary-rgba015);
  transform: translateX(8rpx);
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #C0C8D0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.option-radio.checked {
  border-color: var(--primary);
  background: #F0F8FB;
  transform: scale(1.1);
}

.option-radio-dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--primary);
  border-radius: 50%;
  animation: scaleIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
}

.option-label {
  font-size: 30rpx;
  color: #1A2A3A;
  line-height: 1.4;
}

/* 底部按钮 */
.footer-btn {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.btn-prev {
  width: 180rpx;
  height: 96rpx;
  background: var(--white);
  color: #4A5B6E;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.btn-prev::after {
  border: none;
}

.btn-prev:active {
  transform: scale(0.95);
  background: #F5F9FC;
}

.btn-submit {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: var(--white);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 4px 20px var(--primary-rgba015);
  position: relative;
  overflow: hidden;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active {
  transform: scale(0.96);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

/* 提交按钮涟漪 */
.btn-submit:not(.disabled)::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 10%, transparent 60%);
  opacity: 0;
  transition: opacity 0s;
  border-radius: inherit;
  pointer-events: none;
}

.btn-submit:not(.disabled):active::after {
  opacity: 1;
}

.btn-submit.disabled {
  background: #E0E4E8;
  color: #C0C8D0;
  box-shadow: none;
}
