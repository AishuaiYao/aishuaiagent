<!-- 测试答题页 -->
<view class="page-container" style="--primary: {{theme.primary}}; --primary-light: {{theme.primaryLight}}; --secondary: {{theme.secondary}}; --accent: {{theme.accent}}; --accent-light: {{theme.accentLight}}; --primary-rgba02: {{theme.primaryRgba02}}; --primary-rgba015: {{theme.primaryRgba015}}; --primary-rgba01: {{theme.primaryRgba01}}; --primary-rgba025: {{theme.primaryRgba025}}; --primary-rgba035: {{theme.primaryRgba035}}; --primary-rgba018: {{theme.primaryRgba018}}; --secondary-rgba01: {{theme.secondaryRgba01}}; --secondary-rgba015: {{theme.secondaryRgba015}};">
  <!-- 进度条 -->
  <view class="progress-wrap">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;">
        <view class="progress-shimmer"></view>
      </view>
    </view>
    <text class="progress-text">{{currentIndex + 1}} / {{totalQuestions}}</text>
  </view>

  <!-- 题目区域（滑动过渡） -->
  <view class="question-anim-wrap">
    <view class="question-card card slide-anim" wx:if="{{animKey % 2 === 0}}" style="animation-name: {{animDirection === 'right' ? 'slideInRight' : 'slideInLeft'}};">
      <text class="question-number">第 {{currentIndex + 1}} 题</text>
      <text class="question-text">{{currentQuestion.text}}</text>
    </view>
    <view class="question-card card slide-anim" wx:else style="animation-name: {{animDirection === 'right' ? 'slideInRight' : 'slideInLeft'}};">
      <text class="question-number">第 {{currentIndex + 1}} 题</text>
      <text class="question-text">{{currentQuestion.text}}</text>
    </view>
  </view>

  <!-- 选项 -->
  <view class="options-list">
    <view
      class="option-item {{selectedValue === item.value ? 'selected' : ''}}"
      wx:for="{{currentQuestion.options}}"
      wx:key="value"
      bind:tap="selectOption"
      data-value="{{item.value}}"
    >
      <view class="option-radio {{selectedValue === item.value ? 'checked' : ''}}">
        <view class="option-radio-dot" wx:if="{{selectedValue === item.value}}"></view>
      </view>
      <text class="option-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer-btn">
    <button class="btn-prev" bind:tap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
    <button
      class="btn-submit {{selectedValue ? '' : 'disabled'}}"
      bind:tap="{{isLastQuestion ? 'submitAnswers' : 'nextQuestion'}}"
    >
      <text wx:if="{{isLastQuestion && !selectedValue}}">请先选择答案</text>
      <text wx:else>{{isLastQuestion ? '✓ 提交答案' : '下一题'}}</text>
    </button>
  </view>
</view>
