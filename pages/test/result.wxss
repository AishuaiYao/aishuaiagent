/* 测试结果页 - 软拟态设计 */

.page-container {
  padding: 24px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部信息 */
.result-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-test-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A2A3A;
  display: block;
  margin-bottom: 8rpx;
}

.result-meta {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.result-date,
.result-age {
  font-size: 26rpx;
  color: #8A9BAA;
}

/* 总分卡片 */
.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, #F0F8FB, #FFFFFF);
  box-shadow: 0 4px 20px rgba(168, 216, 234, 0.1);
}

.score-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #1A2A3A;
  line-height: 1;
}

.score-unit {
  font-size: 28rpx;
  color: #4A5B6E;
  margin-bottom: 12rpx;
}

.score-badge {
  padding: 8rpx 32rpx;
  border-radius: 50rpx;
  margin: 12rpx 0;
}

.score-badge text {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.score-compare {
  font-size: 24rpx;
  color: #A8D8EA;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 区域标题 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-bottom: 16rpx;
  display: block;
}

/* 维度列表 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dimension-item {
  padding: 20rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.dimension-name {
  font-size: 26rpx;
  color: #1A2A3A;
  font-weight: 500;
}

.dimension-score {
  font-size: 26rpx;
  color: #A8D8EA;
  font-weight: 600;
}

.dimension-bar-wrap {
  height: 12rpx;
  background: #E8ECF0;
  border-radius: 6rpx;
  overflow: hidden;
}

.dimension-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* 雷达图 */
.radar-canvas-wrap {
  width: 100%;
  height: 500rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.radar-canvas {
  width: 100%;
  height: 100%;
}

/* 建议卡片 */
.advice-card {
  padding: 32rpx;
  border-radius: var(--radius);
  background: var(--white);
  box-shadow: var(--shadow);
}

.advice-summary {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-bottom: 20rpx;
  line-height: 1.6;
  display: block;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.advice-item {
  display: flex;
  align-items: flex-start;
}

.advice-dot {
  color: #A8D8EA;
  font-weight: 700;
  margin-right: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.advice-text {
  font-size: 26rpx;
  color: #4A5B6E;
  line-height: 1.5;
  flex: 1;
}

/* 底部操作 */
.footer-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  padding: 24rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: linear-gradient(135deg, #A8D8EA, #FFD3B4);
  color: #FFFFFF;
  box-shadow: 0 4px 20px rgba(168, 216, 234, 0.15);
}

.action-btn.secondary {
  background: var(--white);
  color: #A8D8EA;
  box-shadow: var(--shadow);
}

.action-btn.full {
  width: 100%;
  flex-basis: 100%;
  background: linear-gradient(135deg, #C7CEEA, #E8EBF7);
  color: #FFFFFF;
}

/* 分享画布隐藏 */
.share-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 600rpx;
  height: 840rpx;
}
