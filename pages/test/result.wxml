<!-- 测试结果页 -->
<view class="page-container">
  <!-- 顶部信息 -->
  <view class="result-header">
    <text class="result-test-name">{{testName}}</text>
    <view class="result-meta">
      <text class="result-date">{{completedAt}}</text>
      <text class="result-age">{{babyAge}}个月</text>
    </view>
  </view>

  <!-- 总分卡片 -->
  <view class="score-card card">
    <text class="score-number">{{overallScore}}</text>
    <text class="score-unit">分</text>
    <view class="score-badge" style="background: {{badgeColor}};">
      <text>{{scoreLevel}}</text>
    </view>
    <text class="score-compare" wx:if="{{compareText}}">{{compareText}}</text>
  </view>

  <!-- 维度得分 -->
  <view class="section" wx:if="{{dimensionList.length > 0}}">
    <text class="section-title">维度分析</text>
    <view class="dimension-list">
      <view class="dimension-item" wx:for="{{dimensionList}}" wx:key="key">
        <view class="dimension-header">
          <text class="dimension-name">{{item.name}}</text>
          <text class="dimension-score">{{item.score}}分</text>
        </view>
        <view class="dimension-bar-wrap">
          <view class="dimension-bar" style="width: {{item.score}}%; background: {{item.color}};"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 雷达图区域（Canvas） -->
  <view class="section" wx:if="{{dimensionsData}}">
    <text class="section-title">综合能力雷达图</text>
    <view class="radar-canvas-wrap">
      <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
    </view>
  </view>

  <!-- 解读与建议 -->
  <view class="section">
    <text class="section-title">解读与建议</text>
    <view class="advice-card card">
      <text class="advice-summary">{{summary}}</text>
      <view class="advice-list">
        <view class="advice-item" wx:for="{{suggestions}}" wx:key="*this">
          <text class="advice-dot">•</text>
          <text class="advice-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="footer-actions">
    <button class="action-btn secondary" bind:tap="goDashboard">查看跟踪看板</button>
    <button class="action-btn primary" bind:tap="retakeQuiz">再测一次</button>
    <button class="action-btn full" bind:tap="shareCard">保存/分享卡片</button>
  </view>

  <!-- 分享卡片离屏 Canvas（隐藏） -->
  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
</view>
