/* ============================================
   全局
   ============================================ */
page {
  background: #0a0a1a;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ============================================
   粒子 Canvas
   ============================================ */
.particle-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

/* ============================================
   背景渐变层 （动态）
   ============================================ */
.bg-gradient {
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(102, 126, 234, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 60%, rgba(240, 147, 251, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 80%, rgba(79, 172, 254, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 80%, rgba(67, 233, 123, 0.08) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
  animation: bg-drift 20s ease-in-out infinite;
}

@keyframes bg-drift {
  0%, 100% { transform: translate(0, 0); }
  33% { transform: translate(2%, 1%); }
  66% { transform: translate(-1%, -2%); }
}

/* ============================================
   网格纹理
   ============================================ */
.bg-grid {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 60rpx 60rpx;
  z-index: 1;
  pointer-events: none;
}

/* ============================================
   主内容区
   ============================================ */
.main-content {
  position: relative;
  z-index: 2;
  padding: 0 32rpx 200rpx;
  padding-top: calc(160rpx + env(safe-area-inset-top));
}

/* ============================================
   Hero 区
   ============================================ */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 60rpx;
}

.hero-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  animation: fadeDown 0.6s ease-out;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #43e97b;
  box-shadow: 0 0 12rpx rgba(67, 233, 123, 0.6);
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.badge-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.hero-title-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #f093fb 50%, #4facfe 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: title-shine 3s ease-in-out infinite;
  background-size: 200% 200%;
}

@keyframes title-shine {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.hero-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 100rpx;
  background: radial-gradient(ellipse, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
  filter: blur(40rpx);
  pointer-events: none;
  z-index: -1;
  animation: glow-pulse 3s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 2rpx;
  animation: fadeDown 0.6s ease-out 0.1s both;
}

@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============================================
   功能卡片区
   ============================================ */
.cards-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 卡片基础 */
.feature-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.3s ease;
}

/* 入场动画 */
.feature-card.card-show {
  animation: cardIn 0.5s ease-out forwards;
  animation-delay: var(--card-delay, 0s);
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 流光边框 */
.card-border-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.04) 50%,
    transparent 100%);
  pointer-events: none;
  animation: shine-move 3s ease-in-out infinite;
  animation-delay: var(--card-delay, 0s);
}

@keyframes shine-move {
  0% { left: -100%; }
  100% { left: 200%; }
}

/* 卡片 hover */
.feature-card:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
  border-color: rgba(255, 255, 255, 0.2);
}

/* 图标圆圈 */
.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.card-icon-wrap::after {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  background: inherit;
  filter: blur(12rpx);
  opacity: 0.4;
  z-index: -1;
}

.card-icon-emoji {
  font-size: 42rpx;
  line-height: 1;
}

/* 卡片文字 */
.card-body {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 箭头 */
.card-arrow {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.arrow-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  transition: all 0.3s;
}

.feature-card:active .card-arrow {
  background: rgba(255, 255, 255, 0.15);
}

.feature-card:active .arrow-icon {
  color: #fff;
  transform: translateX(4rpx);
}

/* ============================================
   底部导航条 (高端风格)
   ============================================ */
.tabbar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 30rpx;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(30, 30, 60, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 32rpx;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.tab-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.tab-active .tab-icon-wrap {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.tab-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.tab-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  transition: color 0.3s;
}

.tab-active .tab-label,
.active-label {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* 中间凸出按钮 */
.tab-center-btn {
  margin-top: -36rpx;
  position: relative;
}

.center-btn-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #f093fb);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.5);
  transition: all 0.3s;
}

.tab-center-btn:active .center-btn-inner {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.center-btn-icon {
  font-size: 44rpx;
  line-height: 1;
}
