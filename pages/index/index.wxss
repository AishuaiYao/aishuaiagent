.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.content {
  padding: 40rpx;
}

/* 底部固定按钮栏 */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 110rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid #ececec;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 用户图标（纯CSS绘制） */
.icon-user {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-user::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 3rpx solid #007aff;
  background: transparent;
  box-sizing: border-box;
}

.icon-user::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 18rpx;
  border: 3rpx solid #007aff;
  border-bottom: none;
  border-radius: 18rpx 18rpx 0 0;
  box-sizing: border-box;
  background: transparent;
}

.tab-item:active .icon-user::before,
.tab-item:active .icon-user::after {
  border-color: #0051d5;
}

.tab-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #007aff;
}
