/* 首页样式 - 软拟态设计 */

.page-container {
  padding: 0 24px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 自定义导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 4px;
  padding-top: env(safe-area-inset-top);
  background: transparent;
}

.nav-bar-left,
.nav-bar-right {
  width: 80rpx;
}

.nav-bar-left {
  display: flex;
  align-items: center;
}

.nav-bar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.hamburger {
  width: 44rpx;
  height: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx;
}

.hamburger-line {
  height: 4rpx;
  background: #1A2A3A;
  border-radius: 2rpx;
}

/* 宝宝信息卡片 */
.baby-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin-top: 16rpx;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 25%, #FFFFFF 90%);
  border-radius: var(--radius);
}

.baby-header:active {
  transform: scale(0.97);
}

.baby-avatar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  font-size: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 50%;
  box-shadow: 0 4px 16px var(--primary-rgba025);
  animation: gentlePulse 3s ease-in-out infinite;
}

.baby-avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  box-shadow: 0 4px 16px var(--primary-rgba025);
}

.baby-info {
  display: flex;
  flex-direction: column;
}

.baby-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-bottom: 4rpx;
}

.baby-age {
  font-size: 24rpx;
  color: #5A9BAB;
  background: rgba(255, 255, 255, 0.6);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  align-self: flex-start;
}

.baby-none {
  padding: 16rpx 0;
}

.baby-none-text {
  color: #7BAFC0;
  font-size: 30rpx;
  font-weight: 500;
}

/* 欢迎语 */
.welcome-text {
  font-size: 32rpx;
  color: #4A5B6E;
  margin: 32px 0 20px;
  font-weight: 500;
}

.welcome-emoji {
  display: inline-block;
  animation: float 3s ease-in-out infinite;
  margin-left: 4rpx;
}

/* 快捷测试卡片 */
.quick-scroll {
  white-space: nowrap;
}

.quick-cards {
  display: inline-flex;
  gap: 16px;
  padding-bottom: 4px;
}

.quick-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 180rpx;
  border-radius: var(--radius);
  background: var(--white);
  border: none;
  box-shadow: var(--shadow);
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  white-space: normal;
  position: relative;
  overflow: hidden;
}

.quick-card:active {
  transform: scale(0.93);
  box-shadow: var(--shadow-hover);
}

.quick-card .quick-icon {
  transition: transform 0.3s ease;
}

.quick-card:active .quick-icon {
  transform: scale(1.2);
}

.quick-card.attention {
  background: linear-gradient(180deg, #F0F8FB 0%, #FFFFFF 100%);
  box-shadow: 0 4px 20px var(--primary-rgba01);
}

.quick-card.attachment {
  background: linear-gradient(180deg, #FEF7F0 0%, #FFFFFF 100%);
  box-shadow: 0 4px 20px rgba(255, 211, 180, 0.1);
}

.quick-card.temperament {
  background: linear-gradient(180deg, #F5F6FC 0%, #FFFFFF 100%);
  box-shadow: 0 4px 20px rgba(199, 206, 234, 0.1);
}

.quick-card.more {
  background: linear-gradient(180deg, #EDF4F7 0%, #FFFFFF 100%);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-bottom: 6rpx;
}

.quick-desc {
  font-size: 20rpx;
  color: #8A9BAA;
}

/* 区域标题 */
.section {
  margin-top: 32px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* 记录列表 */
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: var(--radius);
  margin-bottom: 12rpx;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.record-item:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-hover);
}

.record-left {
  display: flex;
  align-items: center;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  transition: transform 0.3s ease;
}

.record-item:active .record-icon {
  transform: scale(1.2);
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A2A3A;
}

.record-date {
  font-size: 22rpx;
  color: #8A9BAA;
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  align-items: center;
}

.record-summary {
  font-size: 24rpx;
  color: var(--primary);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.record-arrow {
  font-size: 24rpx;
  color: #C0C8D0;
}

/* 空态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #4A5B6E;
}

.empty-desc {
  font-size: 24rpx;
  color: #8A9BAA;
  margin-top: 8rpx;
}
