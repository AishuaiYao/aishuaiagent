.profile {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #007aff 0%, #5ac8fa 100%);
}

.user-card {
  position: absolute;
  top: 90rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #ffffff;
  background: #ffffff;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: block;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  background: #e9ecef;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.default-icon {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.mini-user::before {
  content: "";
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #adb5bd;
}

.mini-user::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 28rpx;
  background: #adb5bd;
  border-radius: 28rpx 28rpx 0 0;
}

.user-info {
  margin-left: 28rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.input-wrap {
  width: 100%;
}

.nickname-input {
  width: 100%;
  height: 56rpx;
  padding: 0;
  background: transparent;
  border: none;
  outline: none;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 56rpx;
}

.nickname-input::placeholder {
  color: rgba(255,255,255,0.7);
}

.auth-btn {
  margin-top: 16rpx;
  margin-left: 0 !important;
  margin-right: 0;
  width: 200rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
  line-height: 60rpx;
  padding: 0;
  align-self: flex-start;
}

.auth-btn::after {
  border: none;
}

/* 数据统计 */
.stats {
  margin: -60rpx 24rpx 24rpx;
  position: relative;
  background: #ffffff;
  border-radius: 20rpx;
  display: flex;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #86868b;
}

/* 菜单列表 */
.menu-group {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 30rpx;
  color: #1d1d1f;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #c7c7cc;
  border-right: 3rpx solid #c7c7cc;
  transform: rotate(45deg);
}
