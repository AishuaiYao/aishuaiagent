/* ============================================
   全局
   ============================================ */
page {
  background: #0a0a1a;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.container {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ============================================
   粒子 Canvas
   ============================================ */
.particle-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

/* ============================================
   背景渐变层
   ============================================ */
.bg-gradient {
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(102, 126, 234, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 60%, rgba(240, 147, 251, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 80%, rgba(79, 172, 254, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 80%, rgba(67, 233, 123, 0.08) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
  animation: bg-drift 20s ease-in-out infinite;
}

@keyframes bg-drift {
  0%, 100% { transform: translate(0, 0); }
  33% { transform: translate(2%, 1%); }
  66% { transform: translate(-1%, -2%); }
}

/* ============================================
   网格纹理
   ============================================ */
.bg-grid {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
  background-size: 60rpx 60rpx;
  z-index: 1;
  pointer-events: none;
}

/* ============================================
   主内容区
   ============================================ */
.main-content {
  position: relative;
  z-index: 2;
  padding: 0 32rpx 200rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
}

/* ============================================
   头像区
   ============================================ */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
  opacity: 0;
  transform: translateY(30rpx);
}

.avatar-section.avatar-show {
  animation: fadeUp 0.6s ease-out forwards;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 头像光环 */
.avatar-ring {
  position: relative;
  padding: 8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #f093fb, #4facfe);
  box-shadow: 0 0 40rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 24rpx;
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.avatar-emoji {
  font-size: 64rpx;
  line-height: 1;
  opacity: 0.6;
}

/* 昵称行 */
.user-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.nickname-input {
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  height: 56rpx;
  line-height: 56rpx;
  max-width: 360rpx;
  padding: 0;
  background: transparent;
  border: none;
  outline: none;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.35);
  font-weight: 400;
  font-size: 32rpx;
}

.edit-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.user-signature {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  max-width: 500rpx;
}

/* 授权按钮 */
.auth-btn {
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3), rgba(240, 147, 251, 0.3));
  border: 1rpx solid rgba(102, 126, 234, 0.4);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #fff;
  line-height: 1.4;
}

.auth-btn::after {
  border: none;
}

.auth-btn-text {
  color: #fff;
  letter-spacing: 2rpx;
}

/* ============================================
   数据统计卡
   ============================================ */
.stats-card {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  opacity: 0;
  transform: translateY(40rpx);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.stats-card.card-show {
  animation: cardIn 0.5s ease-out forwards;
  animation-delay: var(--card-delay, 0s);
}

.stats-row {
  display: flex;
  padding: 36rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea, #f093fb);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 2rpx;
}

/* ============================================
   菜单卡片
   ============================================ */
.menu-group {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  opacity: 0;
  transform: translateY(40rpx);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.menu-group.card-show {
  animation: cardIn 0.5s ease-out forwards;
  animation-delay: var(--card-delay, 0s);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-hover {
  background: rgba(255, 255, 255, 0.06);
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.menu-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.25);
}

/* ============================================
   退出按钮
   ============================================ */
.logout-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  margin-top: 20rpx;
  opacity: 0;
  transform: translateY(40rpx);
  transition: all 0.3s;
}

.logout-btn.card-show {
  animation: cardIn 0.5s ease-out forwards;
  animation-delay: var(--card-delay, 0s);
}

.logout-btn:active {
  background: rgba(255, 80, 80, 0.15);
  border-color: rgba(255, 80, 80, 0.3);
}

.logout-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 4rpx;
}

/* ============================================
   通用动画
   ============================================ */
@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 流光边框 */
.card-border-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.04) 50%,
    transparent 100%);
  pointer-events: none;
  animation: shine-move 3s ease-in-out infinite;
  animation-delay: var(--card-delay, 0s);
}

@keyframes shine-move {
  0% { left: -100%; }
  100% { left: 200%; }
}

/* ============================================
   底部导航条
   ============================================ */
.tabbar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 30rpx;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(30, 30, 60, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 36rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 32rpx;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.tab-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.tab-active .tab-icon-wrap {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.tab-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.tab-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  transition: color 0.3s;
}

.tab-active .tab-label,
.active-label {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* 中间凸出按钮 */
.tab-center-btn {
  margin-top: -36rpx;
  position: relative;
}

.center-btn-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #f093fb);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.5);
  transition: all 0.3s;
}

.tab-center-btn:active .center-btn-inner {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.center-btn-icon {
  font-size: 44rpx;
  line-height: 1;
}
