<view class="profile">
  <!-- 头部区域 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="user-card">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="scaleToFill" />
        <view wx:else class="avatar-default">
          <view class="default-icon">
            <view class="mini-user"></view>
          </view>
        </view>
      </view>
      <view class="user-info">
        <input id="nicknameInput" class="nickname-input" type="nickname" value="{{userInfo.nickName}}" placeholder="点击一键授权" focus="{{nicknameFocus}}" bindinput="onNicknameInput" bindblur="onNicknameInput" />
        <button id="avatarBtn" class="auth-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">一键授权</button>

      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <view class="stat-num">{{item.num}}</view>
      <view class="stat-label">{{item.label}}</view>
    </view>
  </view>

  <!-- 设置项列表 -->
  <view class="menu-group">
    <view class="menu-item" wx:for="{{['我的对话','我的收藏','使用记录']}}" wx:key="*this">
      <text class="menu-text">{{item}}</text>
      <view class="menu-arrow"></view>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" wx:for="{{['账号设置','消息通知','帮助与反馈','关于我们']}}" wx:key="*this">
      <text class="menu-text">{{item}}</text>
      <view class="menu-arrow"></view>
    </view>
  </view>
</view>
