/* 我的宝宝 - 软拟态设计 */

.page-container {
  padding: 0 24px;
  padding-bottom: 32px;
  min-height: 100vh;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 4px;
  padding-top: env(safe-area-inset-top);
}

.nav-bar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.nav-bar-right {
  width: 80rpx;
}

.hamburger {
  width: 44rpx;
  height: 36rpx;
  padding: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.hamburger-line {
  height: 4rpx;
  background: #1A2A3A;
  border-radius: 2rpx;
}

.baby-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.baby-card {
  padding: 24rpx;
  border-radius: var(--radius);
  background: var(--white);
  box-shadow: var(--shadow);
  position: relative;
  border: none;
  transition: all 0.3s ease;
}

.baby-card.current {
  background: linear-gradient(135deg, #F0F8FB, #FFFFFF);
  box-shadow: 0 4px 20px rgba(168, 216, 234, 0.12);
}

.baby-card-main {
  display: flex;
  align-items: center;
}

.bc-avatar {
  font-size: 56rpx;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F0F8FB, #D6EEF5);
  border-radius: 50%;
  margin-right: 20rpx;
}

.bc-info {
  flex: 1;
}

.bc-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.bc-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-right: 12rpx;
}

.bc-tag {
  font-size: 20rpx;
  background: #A8D8EA;
  color: #FFFFFF;
  padding: 2rpx 14rpx;
  border-radius: var(--radius-sm);
}

.bc-detail {
  font-size: 24rpx;
  color: #4A5B6E;
  display: block;
}

.bc-note {
  font-size: 22rpx;
  color: #8A9BAA;
  display: block;
  margin-top: 4rpx;
}

.baby-card-actions {
  display: flex;
  gap: 28rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8ECF0;
}

.bc-action {
  font-size: 24rpx;
  color: #A8D8EA;
  font-weight: 500;
  transition: all 0.2s ease;
}

.bc-action:active {
  transform: scale(0.95);
}

.bc-action.danger {
  color: #E07B6E;
}

/* 右下角悬浮按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 80rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #A8D8EA, #FFD3B4);
  box-shadow: 0 8px 24px rgba(168, 216, 234, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.3s ease;
}

.fab:active {
  transform: scale(0.9);
  box-shadow: 0 4px 12px rgba(168, 216, 234, 0.25);
}

.fab-icon {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24px 24px 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

.modal.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.modal-close {
  font-size: 32rpx;
  color: #C0C8D0;
  padding: 8rpx;
}

.modal-close:active {
  transform: scale(0.95);
}

.modal-body {
  padding: 0 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1A2A3A;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  height: 88rpx;
  background: #F5F7FA;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1A2A3A;
}

.form-picker {
  height: 88rpx;
  background: #F5F7FA;
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1A2A3A;
  display: flex;
  align-items: center;
}

.form-picker.placeholder {
  color: #C0C8D0;
}

.gender-options {
  display: flex;
  gap: 20rpx;
}

.gender-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F7FA;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: #4A5B6E;
  border: none;
  transition: all 0.2s ease;
}

.gender-item:active {
  transform: scale(0.95);
}

.gender-item.selected {
  background: #F0F8FB;
  color: #5A9BAB;
  font-weight: 600;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 32rpx;
}

.modal-footer button {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 600;
}

.modal-footer button::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #A8D8EA, #FFD3B4);
  color: #FFFFFF;
  border-radius: 50rpx;
  box-shadow: 0 4px 20px rgba(168, 216, 234, 0.15);
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
}

.btn-primary[disabled] {
  background: #E0E4E8;
  color: #C0C8D0;
  box-shadow: none;
}

.btn-secondary {
  background: #F0F2F5;
  color: #4A5B6E;
  border-radius: 50rpx;
  border: none;
}

.btn-secondary:active {
  transform: scale(0.95);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #4A5B6E;
}

.empty-desc {
  font-size: 24rpx;
  color: #8A9BAA;
  margin-top: 8rpx;
}
